# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:8501
OPENROUTER_TITLE=FinLit Chatbot

# Telegram
TELEGRAM_BOT_TOKEN=

# Models via OpenRouter
EMBEDDING_MODEL=text-embedding-3-small
FAST_MODEL=openai/gpt-4.1-mini
SMART_MODEL=openai/gpt-4.1

# RAG config
RAG_CHROMA_DIR=.chroma
RAG_SIMILARITY_SPACE=cosine
RAG_TOP_K=4
RAG_CANDIDATE_MULTIPLIER=4
RAG_TITLE_BOOST_WEIGHT=0.35
RAG_COLLECTION_INVESTMENT=investment_education
RAG_COLLECTION_MONEY=money_management

# LangSmith observability
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fin-lit-chatbot
